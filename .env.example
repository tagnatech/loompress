# Server
# Fresh installs can create this file from /install/database instead of editing it manually.
NODE_ENV=development
PORT=4100

# Database — direct PostgreSQL connection string (Supabase or self-hosted)
DATABASE_URL=postgresql://postgres:password@localhost:5432/loompress

# Session — generate with: openssl rand -base64 32
# Must be at least 32 characters
SESSION_SECRET=change-me-to-a-strong-random-string

# File uploads
ASSETS_DIR=./assets
UPLOAD_DIR=./uploads-data
UPLOAD_MAX_SIZE_MB=20

# Reverse proxy / security
# Set to 1 behind Caddy, Nginx, or another single reverse proxy
TRUST_PROXY=false

# Basic abuse protection
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000
COMMENT_RATE_LIMIT_MAX=10
COMMENT_RATE_LIMIT_WINDOW_MS=600000

# Optional: base URL for admin (used in emails/links)
ADMIN_BASE_URL=http://localhost:4100

# Plugins
# Auto-discovers plugins from this directory when PLUGINS is empty
PLUGINS_DIR=./plugins
# Optional comma-separated list of plugin files or directories
# PLUGINS=./plugins/my-plugin,./plugins/another-plugin

# Optional: used by the bundled AI Autoblog plugin when no key is stored in settings
# OPENROUTER_API_KEY=
