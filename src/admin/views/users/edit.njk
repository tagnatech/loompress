{% extends "../layout.njk" %}
{% set activeNav = 'users' %}

{% block content %}
<div class="page-header">
  <h1>{{ "Edit User Role" if user else "Add User" }}</h1>
  <a href="/admin/users" class="btn">Back</a>
</div>

<form method="POST" action="{{ '/admin/users/' + user.id + '/edit' if user else '/admin/users/new' }}" class="form-narrow">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}">

  {% if not user %}
  <div class="form-group">
    <label for="email">Email</label>
    <input type="email" id="email" name="email" required autocomplete="email" class="form-input">
  </div>

  <div class="form-group">
    <label for="display_name">Display Name</label>
    <input type="text" id="display_name" name="display_name" required autocomplete="name" class="form-input">
  </div>

  <div class="form-group">
    <label for="password">Password</label>
    <input type="password" id="password" name="password" required minlength="10" autocomplete="new-password" class="form-input">
  </div>
  {% else %}
  <p><strong>{{ user.display_name }}</strong> ({{ user.email }})</p>
  {% endif %}

  <div class="form-group">
    <label for="role">Role</label>
    <select id="role" name="role" class="form-input">
      <option value="author" {{ 'selected' if not user or user.site_role == 'author' }}>Author</option>
      <option value="admin" {{ 'selected' if user and user.site_role == 'admin' }}>Admin</option>
    </select>
  </div>

  <button type="submit" class="btn btn--primary">{{ "Update Role" if user else "Add User" }}</button>
</form>
{% endblock %}
