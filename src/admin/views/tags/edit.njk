{% extends "../layout.njk" %}
{% set activeNav = 'tags' %}

{% block content %}
<div class="page-header">
  <h1>{{ "Edit Tag" if tag else "New Tag" }}</h1>
  <a href="/admin/tags" class="btn">Back</a>
</div>

<form method="POST" action="{{ '/admin/tags/' + tag.id + '/edit' if tag else '/admin/tags/new' }}" class="form-narrow">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}">

  <div class="form-group">
    <label for="name">Name</label>
    <input type="text" id="name" name="name" value="{{ tag.name if tag else '' }}" required class="form-input">
  </div>

  <div class="form-group">
    <label for="slug">Slug</label>
    <input type="text" id="slug" name="slug" value="{{ tag.slug if tag else '' }}" class="form-input">
  </div>

  <button type="submit" class="btn btn--primary">{{ "Update" if tag else "Create" }} Tag</button>
</form>
{% endblock %}
