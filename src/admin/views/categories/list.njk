{% extends "../layout.njk" %}
{% set activeNav = 'categories' %}

{% block content %}
<div class="page-header">
  <h1>Categories</h1>
  <a href="/admin/categories/new" class="btn btn--primary">New Category</a>
</div>

{% if categories.length %}
<table class="table">
  <thead>
    <tr>
      <th>Name</th>
      <th>Slug</th>
      <th>Parent</th>
      <th>Posts</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    {% for cat in categories %}
    <tr>
      <td><a href="/admin/categories/{{ cat.id }}/edit">{{ cat.name }}</a></td>
      <td>{{ cat.slug }}</td>
      <td>
        {% for parent in categories %}
          {% if parent.id == cat.parent_id %}{{ parent.name }}{% endif %}
        {% endfor %}
      </td>
      <td>{{ cat.post_count or 0 }}</td>
      <td class="actions">
        <a href="/admin/categories/{{ cat.id }}/edit" class="btn btn--sm">Edit</a>
        <form method="POST" action="/admin/categories/{{ cat.id }}/delete" style="display:inline"
              onsubmit="return confirm('Delete this category?')">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <button type="submit" class="btn btn--sm btn--danger">Delete</button>
        </form>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
  <p class="empty-state">No categories yet.</p>
{% endif %}
{% endblock %}
