{% extends "../layout.njk" %}
{% set activeNav = 'categories' %}

{% block content %}
<div class="page-header">
  <h1>{{ "Edit Category" if category else "New Category" }}</h1>
  <a href="/admin/categories" class="btn">Back</a>
</div>

<form method="POST" action="{{ '/admin/categories/' + category.id + '/edit' if category else '/admin/categories/new' }}" class="form-narrow">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}">

  <div class="form-group">
    <label for="name">Name</label>
    <input type="text" id="name" name="name" value="{{ category.name if category else '' }}" required class="form-input">
  </div>

  <div class="form-group">
    <label for="slug">Slug</label>
    <input type="text" id="slug" name="slug" value="{{ category.slug if category else '' }}" class="form-input">
  </div>

  <div class="form-group">
    <label for="parent_id">Parent Category</label>
    <select id="parent_id" name="parent_id" class="form-input">
      <option value="">None (top-level)</option>
      {% for cat in categories %}
        {% if not category or cat.id != category.id %}
        <option value="{{ cat.id }}" {{ 'selected' if category and category.parent_id == cat.id }}>{{ cat.name }}</option>
        {% endif %}
      {% endfor %}
    </select>
  </div>

  <div class="form-group">
    <label for="description">Description</label>
    <textarea id="description" name="description" rows="3" class="form-input">{{ category.description if category else '' }}</textarea>
  </div>

  <button type="submit" class="btn btn--primary">{{ "Update" if category else "Create" }} Category</button>
</form>
{% endblock %}
