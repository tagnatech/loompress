{% extends "../layout.njk" %}
{% set activeNav = 'settings' %}

{% block content %}
<div class="page-header">
  <h1>Comment Settings</h1>
</div>

<div class="settings-nav">
  <a href="/admin/settings" class="settings-nav__link">General</a>
  <a href="/admin/settings/comments" class="settings-nav__link settings-nav__link--active">Comments</a>
  <a href="/admin/settings/seo" class="settings-nav__link">SEO</a>
  <a href="/admin/settings/themes" class="settings-nav__link">Themes</a>
</div>

<form method="POST" action="/admin/settings/comments">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}">

  <div class="settings-section">
    <div class="form-group form-group--checkbox">
      <label>
        <input type="checkbox" name="enabled" {{ 'checked' if settings['comments.enabled'] == 'true' }}>
        Enable comments on new posts
      </label>
    </div>

    <div class="form-group form-group--checkbox">
      <label>
        <input type="checkbox" name="moderation" {{ 'checked' if settings['comments.moderation'] == 'true' }}>
        Hold comments for moderation before publishing
      </label>
    </div>

    <div class="form-group form-group--checkbox">
      <label>
        <input type="checkbox" name="require_email" {{ 'checked' if settings['comments.require_email'] == 'true' }}>
        Require email address for comments
      </label>
    </div>

    <div class="form-group form-group--checkbox">
      <label>
        <input type="checkbox" name="allow_nested" {{ 'checked' if settings['comments.allow_nested'] == 'true' }}>
        Allow threaded (nested) comments
      </label>
    </div>

    <div class="form-group">
      <label for="max_depth">Maximum nesting depth</label>
      <input type="number" name="max_depth" id="max_depth" class="form-control form-control--sm" value="{{ settings['comments.max_depth'] }}" min="1" max="10">
    </div>
  </div>

  <button type="submit" class="btn btn--primary">Save Comment Settings</button>
</form>
{% endblock %}
