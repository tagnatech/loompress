{% extends "../layout.njk" %}
{% set activeNav = 'posts' %}

{% block content %}
<div class="page-header">
  <h1>Posts</h1>
  <a href="/admin/posts/new" class="btn btn--primary">New Post</a>
</div>

<div class="filter-bar">
  <a href="/admin/posts" class="filter-link {% if status == 'all' %}filter-link--active{% endif %}">All</a>
  <a href="/admin/posts?status=published" class="filter-link {% if status == 'published' %}filter-link--active{% endif %}">Published</a>
  <a href="/admin/posts?status=draft" class="filter-link {% if status == 'draft' %}filter-link--active{% endif %}">Drafts</a>
  <a href="/admin/posts?status=scheduled" class="filter-link {% if status == 'scheduled' %}filter-link--active{% endif %}">Scheduled</a>
</div>

{% if posts.length %}
<table class="table">
  <thead>
    <tr>
      <th>Title</th>
      <th>Author</th>
      <th>Status</th>
      <th>Date</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    {% for post in posts %}
    <tr>
      <td><a href="/admin/posts/{{ post.id }}/edit">{{ post.title }}</a></td>
      <td>{{ post.author_name or '—' }}</td>
      <td><span class="badge badge--{{ post.status }}">{{ post.status }}</span></td>
      <td>{{ post.updated_at | formatDate('DD MMM YYYY') }}</td>
      <td class="actions">
        <a href="/admin/posts/{{ post.id }}/edit" class="btn btn--sm">Edit</a>
        {% if post.status == 'draft' %}
          <form method="POST" action="/admin/posts/{{ post.id }}/publish" style="display:inline">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <button type="submit" class="btn btn--sm btn--success">Publish</button>
          </form>
        {% elif post.status == 'published' %}
          <form method="POST" action="/admin/posts/{{ post.id }}/unpublish" style="display:inline">
            <input type="hidden" name="_csrf" value="{{ csrfToken }}">
            <button type="submit" class="btn btn--sm btn--warning">Unpublish</button>
          </form>
        {% endif %}
        <form method="POST" action="/admin/posts/{{ post.id }}/delete" style="display:inline"
              onsubmit="return confirm('Delete this post?')">
          <input type="hidden" name="_csrf" value="{{ csrfToken }}">
          <button type="submit" class="btn btn--sm btn--danger">Delete</button>
        </form>
      </td>
    </tr>
    {% endfor %}
  </tbody>
</table>

{% if totalPages > 1 %}
<div class="pagination">
  {% if page > 1 %}
    <a href="/admin/posts?page={{ page - 1 }}{% if status != 'all' %}&status={{ status }}{% endif %}" class="pagination__link">&laquo; Prev</a>
  {% endif %}
  <span class="pagination__info">Page {{ page }} of {{ totalPages }}</span>
  {% if page < totalPages %}
    <a href="/admin/posts?page={{ page + 1 }}{% if status != 'all' %}&status={{ status }}{% endif %}" class="pagination__link">Next &raquo;</a>
  {% endif %}
</div>
{% endif %}
{% else %}
  <p class="empty-state">No posts found. <a href="/admin/posts/new">Create your first post</a>.</p>
{% endif %}
{% endblock %}
