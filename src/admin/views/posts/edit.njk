{% extends "../layout.njk" %}
{% set activeNav = 'posts' %}

{% block head %}
<link rel="stylesheet" href="https://unpkg.com/trix@2.1.12/dist/trix.css">
<script src="https://unpkg.com/trix@2.1.12/dist/trix.umd.min.js"></script>
{% endblock %}

{% block content %}
<div class="page-header">
  <h1>{{ "Edit Post" if post else "New Post" }}</h1>
  <a href="/admin/posts" class="btn">Back to Posts</a>
</div>

<form method="POST" action="{{ '/admin/posts/' + post.id + '/edit' if post else '/admin/posts/new' }}" class="post-form">
  <input type="hidden" name="_csrf" value="{{ csrfToken }}">

  <div class="form-layout">
    <div class="form-layout__main">
      <div class="form-group">
        <label for="title">Title</label>
        <input type="text" id="title" name="title" value="{{ post.title if post else '' }}" required class="form-input">
      </div>

      <div class="form-group">
        <label for="slug">Slug</label>
        <input type="text" id="slug" name="slug" value="{{ post.slug if post else '' }}" class="form-input" placeholder="Auto-generated from title if left blank">
      </div>

      <div class="form-group">
        <label for="excerpt">Excerpt</label>
        <textarea id="excerpt" name="excerpt" rows="3" class="form-input">{{ post.excerpt if post else '' }}</textarea>
      </div>

      <div class="form-group">
        <label>Body</label>
        <input id="body" type="hidden" name="body" value="{{ post.body if post else '' }}">
        <trix-editor input="body" class="trix-content"></trix-editor>
      </div>

      <div class="form-row">
        <div class="form-group">
          <label for="meta_title">Meta Title (SEO)</label>
          <input type="text" id="meta_title" name="meta_title" value="{{ post.meta_title if post else '' }}" class="form-input">
        </div>
        <div class="form-group">
          <label for="meta_description">Meta Description (SEO)</label>
          <textarea id="meta_description" name="meta_description" rows="2" class="form-input">{{ post.meta_description if post else '' }}</textarea>
        </div>
      </div>
    </div>

    <div class="form-layout__sidebar">
      <div class="form-card">
        <h3>Publish</h3>
        <div class="form-group">
          <label>Status</label>
          <div class="radio-group">
            <label><input type="radio" name="status" value="draft" {{ 'checked' if not post or post.status == 'draft' }}> Draft</label>
            <label><input type="radio" name="status" value="published" {{ 'checked' if post and post.status == 'published' }}> Published</label>
            <label><input type="radio" name="status" value="scheduled" {{ 'checked' if post and post.status == 'scheduled' }}> Scheduled</label>
            <label><input type="radio" name="status" value="private" {{ 'checked' if post and post.status == 'private' }}> Private</label>
          </div>
        </div>
        <div class="form-group">
          <label for="scheduled_at">Schedule Date</label>
          <input type="datetime-local" id="scheduled_at" name="scheduled_at"
                 value="{{ post.scheduled_at | formatDate('YYYY-MM-DDTHH:mm') if post and post.scheduled_at else '' }}"
                 class="form-input">
        </div>
        <button type="submit" class="btn btn--primary btn--full">
          {{ "Update" if post else "Create" }} Post
        </button>
      </div>

      <div class="form-card">
        <h3>Featured Image</h3>
        <input type="hidden" name="featured_image_id" id="featured_image_id"
               value="{{ post.featured_image_id if post else '' }}">
        {% if post and post.featured_image_url %}
          <img src="{{ post.featured_image_url }}" alt="Featured image" class="featured-preview" id="featured-preview">
        {% else %}
          <img src="" alt="" class="featured-preview" id="featured-preview" style="display:none">
        {% endif %}
        <button type="button" class="btn btn--sm" id="media-picker-btn">Select Image</button>
      </div>

      <div class="form-card">
        <h3>Categories</h3>
        {% for cat in categories %}
        <label class="checkbox-label">
          <input type="checkbox" name="category_ids" value="{{ cat.id }}"
                 {{ 'checked' if cat.id in postCategories }}>
          {{ cat.name }}
        </label>
        {% else %}
          <p class="text-muted">No categories yet.</p>
        {% endfor %}
      </div>

      <div class="form-card">
        <h3>Tags</h3>
        <input type="text" name="tags" class="form-input"
               value="{{ postTags | join(', ', 'name') if postTags else '' }}"
               placeholder="Comma-separated tags">
      </div>
    </div>
  </div>
</form>
{% endblock %}

{% block scripts %}
<script>
  // Auto-generate slug from title
  const titleInput = document.getElementById('title');
  const slugInput = document.getElementById('slug');
  if (titleInput && slugInput && !slugInput.value) {
    titleInput.addEventListener('input', () => {
      slugInput.value = titleInput.value
        .toLowerCase().trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/[\s_]+/g, '-')
        .replace(/-+/g, '-');
    });
  }
</script>
{% endblock %}
