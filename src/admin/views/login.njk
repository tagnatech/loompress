<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login — LoomPress</title>
  {{ (brandHeadHtml or defaultBrandHeadHtml) | safe }}
  <link rel="stylesheet" href="/admin/css/admin.css">
</head>
<body class="login-body">
  <div class="login-card">
    <h1 class="login-card__title">LoomPress</h1>
    <p class="login-card__subtitle">Sign in to your account</p>

    {% if flashMessages.error %}
      {% for msg in flashMessages.error %}
        <div class="alert alert--error">{{ msg }}</div>
      {% endfor %}
    {% endif %}
    {% if flashMessages.success %}
      {% for msg in flashMessages.success %}
        <div class="alert alert--success">{{ msg }}</div>
      {% endfor %}
    {% endif %}

    <form method="POST" action="/admin/login">
      <input type="hidden" name="_csrf" value="{{ csrfToken }}">
      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required autofocus autocomplete="username" class="form-input">
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input type="password" id="password" name="password" required autocomplete="current-password" class="form-input">
      </div>
      <button type="submit" class="btn btn--primary btn--full">Sign In</button>
    </form>
  </div>
</body>
</html>
